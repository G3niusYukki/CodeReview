# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_review_db
DB_USER=postgres
DB_PASSWORD=postgres

# AI Provider
GLM5_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM5_API_KEY=your_glm_api_key

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_BASIC_PRICE_ID=price_basic_placeholder
STRIPE_PRO_PRICE_ID=price_pro_placeholder
STRIPE_TEAM_PRICE_ID=price_team_placeholder
